{
	"name": "albion-profit",
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"check": "pnpm run biome && pnpm run knip",
		"build": "paraglide-js compile --project ./project.inlang --outdir ./src\\paraglide && vite build",
		"biome": "biome check src --write",
		"knip": "knip",
		"preview": "vite preview",
		"mongodb:start": "mongod --dbpath ./src/data/mongodb/data/db --port 27018",
		"postinstall": "paraglide-js compile --project ./project.inlang --outdir ./src\\paraglide"
	},
	"dependencies": {
		"@formkit/auto-animate": "^0.9.0",
		"@inlang/paraglide-vite": "^1.4.0",
		"@mantine/charts": "^9.3.2",
		"@mantine/core": "^9.3.2",
		"@mantine/hooks": "^9.3.2",
		"@mantine/notifications": "^9.3.2",
		"@tabler/icons-react": "^3.44.0",
		"dame": "^1.2.7",
		"dayjs": "^1.11.21",
		"mobx": "^6.16.1",
		"mobx-react-lite": "^4.1.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-router-dom": "^7.18.0",
		"recharts": "^3.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@inlang/paraglide-js": "^2.15.3",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.3",
		"knip": "^6.17.1",
		"postcss": "^8.5.15",
		"postcss-preset-mantine": "1.18.0",
		"postcss-simple-vars": "^7.0.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.16"
	},
	"packageManager": "pnpm@10.12.4",
	"pnpm": {
		"overrides": {
			"@types/react": "19.2.14"
		}
	}
}
