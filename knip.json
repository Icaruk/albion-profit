{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"tags": ["-lintignore"],
	"ignoreExportsUsedInFile": true,
	"entry": ["src/data/scripts/**/*.js"],
	"project": ["src/**/*.{js,jsx}"],
	"paths": {
		"@/*": ["./src/*"],
		"@": ["./src"]
	},
	"ignoreFiles": [
		"src/paraglide/**/*.js",
		"src/data/**",
		"src/pages/home/partials/ItemSelector.jsx"
	],
	"ignoreIssues": {
		"src/paraglide/**": ["exports"],
		"src/mobx/rootStore.js": ["exports"]
	},
	"ignoreBinaries": ["mongod"]
}
